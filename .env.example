# ── MongoDB (Atlas, region: Mumbai ap-south-1 to match Vercel bom1) ──
MONGODB_URI="mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/niatspi?retryWrites=true&w=majority&appName=Cluster0"

# ── BigQuery service account (full JSON on a single line) ──
BIGQUERY_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"kossip-helpers", ... }'
BQ_PROJECT_ID="kossip-helpers"
BQ_LOCATION="asia-south1"

# ── Auth ──
# 30-day sessions. Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# ── Google sign-in (OAuth 2.0 Web client) ──
# Create at https://console.cloud.google.com/apis/credentials
#  • Authorized JavaScript origin:  <NEXT_PUBLIC_APP_URL>  (e.g. https://niat-spi.vercel.app)
#  • Authorized redirect URI:       <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
# Only emails that already exist as active staff users can sign in.
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# ── Cron protection (Vercel sends Authorization: Bearer $CRON_SECRET) ──
CRON_SECRET="change-me-too"

# ── App ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
